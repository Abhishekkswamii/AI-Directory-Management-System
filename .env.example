# Example .env configuration file for Aether
# Copy this to .env and customize your settings
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
# ===========================================
# AI Provider Configuration
# ===========================================

# Which AI to use: "ollama" (local, free) or "openai" (cloud, paid)
AETHER_AI_PROVIDER=ollama

# Ollama settings (if using Ollama)
AETHER_OLLAMA_HOST=http://localhost:11434
AETHER_OLLAMA_MODEL=llama2

# OpenAI settings (if using OpenAI)
# Get your API key from https://platform.openai.com/api-keys
AETHER_OPENAI_API_KEY=your-api-key-here
AETHER_OPENAI_MODEL=gpt-3.5-turbo

# ===========================================
# Storage Configuration
# ===========================================

# Where to store the database (leave empty for default: ~/.aether/aether.db)
# AETHER_DATABASE_PATH=/custom/path/aether.db

# Where to store vector embeddings (leave empty for default: ~/.aether/vector_store)
# AETHER_VECTOR_DB_PATH=/custom/path/vector_store

# ===========================================
# Organization Settings
# ===========================================

# How to organize files: "move" or "copy"
AETHER_ORGANIZE_MODE=move

# Create backups before organizing (highly recommended!)
AETHER_CREATE_BACKUP=true

# Maximum file size to process in MB (larger files are skipped)
AETHER_MAX_FILE_SIZE_MB=100

# ===========================================
# Scanning Settings
# ===========================================

# Scan hidden files and folders (usually not needed)
AETHER_SCAN_HIDDEN_FILES=false

# Follow symbolic links during scanning
AETHER_FOLLOW_SYMLINKS=false

# ===========================================
# UI Settings
# ===========================================

# Show beautiful emojis in output
AETHER_USE_EMOJIS=true

# Color theme: "auto", "light", or "dark"
AETHER_COLOR_THEME=auto

# Show detailed debug logs
AETHER_VERBOSE=false

# ===========================================
# Category Settings
# ===========================================

# Let AI create smart custom categories based on content
AETHER_SMART_CATEGORIES=true
